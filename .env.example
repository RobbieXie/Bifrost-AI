# 公共模型服务连接
OPENAI_API_KEY=123456
OPENAI_API_BASE=http://localhost:3000/gemini-antigravity/v1/

# DC 和 LA 共用的默认模型参数
MODEL_NAME=gemini-3-flash-preview
MODEL_TEMPERATURE=0.0
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT=60
MODEL_MAX_RETRIES=2

# DC 独立覆盖，需要时取消注释
# DC_MODEL_NAME=gemini-3-flash-preview
# DC_MODEL_TEMPERATURE=0.0
# DC_MODEL_MAX_TOKENS=4096
# DC_MODEL_TIMEOUT=60
# DC_MODEL_MAX_RETRIES=2
# DC 意图识别、顶层路由、任务内指令识别使用的近 N 轮对话上下文。
DC_CONTEXT_TURNS=4

# LA 独立覆盖，需要时取消注释
# LA_MODEL_NAME=gemini-3-flash-preview
# LA_MODEL_TEMPERATURE=0.0
# LA_MODEL_MAX_TOKENS=4096
# LA_MODEL_TIMEOUT=60
# LA_MODEL_MAX_RETRIES=2

# false 适合测试换模型：忽略数据库中的 Agent 模型名和 temperature。
# true 适合按 Agent 配置不同模型。
LA_USE_DB_MODEL_CONFIG=false

# 基础设施与服务地址
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/hybrid_ai
AGENT_SERVICE_URL=http://localhost:8001
WORKFLOW_ENGINE_URL=http://localhost:8002

# 开放能力层
DIALOGUE_CONTROL_URL=http://localhost:8000
AUTH_GATEWAY_URL=http://localhost:8010
AUTH_GATEWAY_ISSUER=http://localhost:8010
AUTH_GATEWAY_TOKEN_SECRET=dev-auth-gateway-secret-change-me
AUTH_GATEWAY_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_GATEWAY_REFRESH_TOKEN_TTL_SECONDS=2592000
OPEN_GATEWAY_PUBLIC_BASE_URL=http://localhost:8011
# 本地开发默认 false，生产或外部联调应改成 true。
OPEN_GATEWAY_AUTH_REQUIRED=false
